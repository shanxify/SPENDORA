{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/static/(.*)", "destination": "/frontend/static/$1" },
    { "source": "/favicon.ico", "destination": "/frontend/favicon.ico" },
    { "source": "/manifest.json", "destination": "/frontend/manifest.json" },
    { "source": "/logo(.*)", "destination": "/frontend/logo$1" },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ]
}
