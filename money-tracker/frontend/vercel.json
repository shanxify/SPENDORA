{
  "rewrites": [
    { "source": "/api/seed-categories(.*)", "destination": "/api/seed-categories.js" },
    { "source": "/api/categories(.*)", "destination": "/api/categories.js" },
    { "source": "/api/merchants(.*)", "destination": "/api/merchants.js" },
    { "source": "/api/stats(.*)", "destination": "/api/stats.js" },
    { "source": "/api/transactions(.*)", "destination": "/api/transactions.js" },
    { "source": "/api/upload(.*)", "destination": "/api/upload.js" },
    { "source": "/api/feedback(.*)", "destination": "/api/feedback.js" },
    { "source": "/((?!static|favicon|manifest|logo|robots).*)", "destination": "/index.html" }
  ]
}
