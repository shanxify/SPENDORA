{
  "name": "money-tracker",
  "version": "1.0.0",
  "description": "PhonePe transaction tracker",
  "scripts": {
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd frontend/api/server && node server.js",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
